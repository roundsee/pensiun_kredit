/* Procedure structure for procedure `sp_update_mutasi_stok` */

DELIMITER $$

/*!50003 CREATE DEFINER=`root`@`localhost` PROCEDURE `sp_update_mutasi_stok`(IN p_kd_brg VARCHAR(50),
    IN p_kd_cus VARCHAR(50),
    IN p_tanggal DATE,
    IN p_username VARCHAR(100),
    IN p_qty INT)
BEGIN
-- Deklarasi Variabel Internal
    DECLARE v_harga DECIMAL(15,2) DEFAULT 0;
    DECLARE v_exists_inv INT DEFAULT 0;
    DECLARE v_exists_mutasi INT DEFAULT 0;
    
    -- Variabel untuk penampung record mutasi sebelumnya
    DECLARE v_nilai_awal DECIMAL(15,2) DEFAULT 0;
    DECLARE v_qty_awal INT DEFAULT 0;
    DECLARE v_stok_opname INT DEFAULT 0;
    DECLARE v_nilai_opname_prev DECIMAL(15,2) DEFAULT 0;
    
    -- Variabel untuk kalkulasi insert mutasi baru
    DECLARE v_qt_tersedia INT DEFAULT 0;
    DECLARE v_nilai_tersedia DECIMAL(15,2) DEFAULT 0;
    DECLARE v_qty_opname INT DEFAULT 0;
    DECLARE v_nilai_opname DECIMAL(15,2) DEFAULT 0;
    DECLARE v_harga_rata_sebelumnya DECIMAL(15,2) DEFAULT 0;
    DECLARE v_nilai_total_opname DECIMAL(15,2) DEFAULT 0;

    -- 1. UPDATE BARANG (Lock Status) BASED ON LOKASI
    IF p_kd_cus = '1316' THEN
        UPDATE barang SET Pcs = 1 WHERE kd_brg = p_kd_brg;
    ELSE
        UPDATE barang SET Renteng = 1 WHERE kd_brg = p_kd_brg;
    END IF;

    -- 2. GET HARGA BARANG
    SELECT COALESCE(harga, 0) INTO v_harga 
    FROM barang 
    WHERE kd_brg = p_kd_brg 
    LIMIT 1;

    -- 3. UPSERT INVENTORY (Check if exists, then update or insert)
	/*
    SELECT COUNT(*) INTO v_exists_inv 
    FROM inventory 
    WHERE kd_brg = p_kd_brg AND kd_cus = p_kd_cus;

    IF v_exists_inv > 0 THEN
        UPDATE inventory 
        SET stok = p_qty 
        WHERE kd_brg = p_kd_brg AND kd_cus = p_kd_cus;
    ELSE
        INSERT INTO inventory (kd_brg, kd_cus, stok, satuan) 
        VALUES (p_kd_brg, p_kd_cus, p_qty, 'Pcs');
    END IF;
*/

    -- 4. PROCESS MUTASI STOK
    SELECT COUNT(*) INTO v_exists_mutasi 
    FROM mutasi_stok 
    WHERE tgl = p_tanggal AND kd_cus = p_kd_cus AND kd_brg = p_kd_brg;

    IF v_exists_mutasi > 0 THEN
        -- Jika data mutasi hari ini sudah ada, lakukan UPDATE
        UPDATE mutasi_stok 
        SET 
            qt_opname_hari    = qt_opname_hari + (p_qty - qt_akhir),
            nilai_opname_hari = nilai_opname_hari + ((p_qty * v_harga) - nilai_akhir),
            qt_akhir          = qt_akhir + (p_qty - qt_akhir),
            qt_tersedia       = p_qty,
            nilai_tersedia    = p_qty * v_harga,
            harga_rata        = CASE WHEN p_qty > 0 THEN (p_qty * v_harga) / p_qty ELSE v_harga END,                                     
            hpp_jual          = CASE WHEN p_qty > 0 THEN ((p_qty * v_harga) / p_qty) * qt_jual ELSE v_harga * qt_jual END,
            nilai_akhir       = CASE WHEN p_qty > 0 THEN ((p_qty * v_harga) / p_qty) * qt_akhir ELSE v_harga * qt_akhir END
        WHERE tgl = p_tanggal AND kd_cus = p_kd_cus AND kd_brg = p_kd_brg;
        
    ELSE
        -- Jika belum ada, cari data dari tanggal terakhir sebelumnya
        SELECT 
            nilai_akhir, qt_akhir, stok_opname, nilai_opname 
            INTO v_nilai_awal, v_qty_awal, v_stok_opname, v_nilai_opname_prev
        FROM mutasi_stok 
        WHERE kd_cus = p_kd_cus AND kd_brg = p_kd_brg 
        ORDER BY tgl DESC 
        LIMIT 1;
        
        -- Proteksi jika data historical tidak ditemukan sama sekali (NULL)
        SET v_nilai_awal = COALESCE(v_nilai_awal, 0);
        SET v_qty_awal = COALESCE(v_qty_awal, 0);
        SET v_stok_opname = COALESCE(v_stok_opname, 0);
        SET v_nilai_opname_prev = COALESCE(v_nilai_opname_prev, 0);

        -- Logika penentuan nilai awal berdasarkan code PHP asli Anda
        IF v_stok_opname != 0 THEN 
            SET v_qty_awal = v_stok_opname; 
        END IF;
        
        IF v_nilai_opname_prev != 0 THEN 
            SET v_nilai_awal = v_nilai_opname_prev; 
        END IF;

        -- Kalkulasi nilai baru
        SET v_qt_tersedia = p_qty;
        SET v_nilai_tersedia = p_qty * v_harga;
        SET v_qty_opname = p_qty - v_qty_awal;
        SET v_nilai_opname = v_nilai_tersedia - v_nilai_awal;

        IF v_qt_tersedia > 0 THEN
            SET v_harga_rata_sebelumnya = v_nilai_tersedia / v_qt_tersedia;
        ELSE
            SET v_harga_rata_sebelumnya = v_harga;
        END IF;

        -- INSERT data baru ke mutasi_stok
        INSERT INTO mutasi_stok (
            tgl, qty_awal, nilai_awal, qt_opname_hari, nilai_opname_hari, 
            qt_tersedia, nilai_tersedia, harga_rata, kd_cus, kd_brg, 
            satuan, qt_akhir, nilai_akhir
        ) VALUES (
            p_tanggal, v_qty_awal, v_nilai_awal, v_qty_opname, v_nilai_opname,
            v_qt_tersedia, v_nilai_tersedia, v_harga_rata_sebelumnya, p_kd_cus, p_kd_brg,
            'Pcs', v_qt_tersedia, v_nilai_tersedia
        );
    END IF;

    -- 5. INSERT LOG DETAIL OPNAME
    SET v_nilai_total_opname = p_qty * v_harga;
    
    INSERT INTO opname_detail (
        kd_cus, kd_brg, tgl, stok_opname, nilai_opname, user_input, waktu_buat
    ) VALUES (
        p_kd_cus, p_kd_brg, p_tanggal, p_qty, v_nilai_total_opname, p_username, NOW()
    );
	END */$$
DELIMITER ;

