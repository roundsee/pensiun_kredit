CREATE TABLE `journal_entries` (
  `id` bigint unsigned NOT NULL AUTO_INCREMENT,
  `transaction_date` date NOT NULL,
  `account_id` bigint unsigned NOT NULL,
  `debit` decimal(15,2) NOT NULL DEFAULT '0.00',
  `credit` decimal(15,2) NOT NULL DEFAULT '0.00',
  `nasabah_id` bigint unsigned DEFAULT NULL,
  `loan_id` bigint unsigned DEFAULT NULL,
  `lender_id` bigint unsigned DEFAULT NULL,
  `reference` varchar(255) DEFAULT NULL,
  `posting_status` enum('posted','reversed') NOT NULL DEFAULT 'posted',
  `reversed_from_id` bigint unsigned DEFAULT NULL,
  `void_reason` varchar(255) DEFAULT NULL,
  `description` varchar(255) NOT NULL,
  `created_at` timestamp NULL DEFAULT NULL,
  `updated_at` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `journal_entries_account_id_foreign` (`account_id`),
  KEY `journal_entries_nasabah_id_foreign` (`nasabah_id`),
  KEY `journal_entries_reversed_from_id_foreign` (`reversed_from_id`),
  KEY `journal_entries_transaction_date_account_id_index` (`transaction_date`,`account_id`),
  KEY `journal_entries_lender_id_transaction_date_index` (`lender_id`,`transaction_date`),
  KEY `journal_entries_loan_id_transaction_date_index` (`loan_id`,`transaction_date`),
  CONSTRAINT `journal_entries_account_id_foreign` FOREIGN KEY (`account_id`) REFERENCES `accounts` (`id`) ON DELETE RESTRICT ON UPDATE CASCADE,
  CONSTRAINT `journal_entries_lender_id_foreign` FOREIGN KEY (`lender_id`) REFERENCES `lenders` (`id`) ON DELETE SET NULL,
  CONSTRAINT `journal_entries_loan_id_foreign` FOREIGN KEY (`loan_id`) REFERENCES `loans` (`id`) ON DELETE SET NULL,
  CONSTRAINT `journal_entries_nasabah_id_foreign` FOREIGN KEY (`nasabah_id`) REFERENCES `users` (`id`) ON DELETE SET NULL,
  CONSTRAINT `journal_entries_reversed_from_id_foreign` FOREIGN KEY (`reversed_from_id`) REFERENCES `journal_entries` (`id`) ON DELETE SET NULL
) ENGINE=InnoDB AUTO_INCREMENT=15 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

